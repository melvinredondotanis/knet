#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <unistd.h>
#include <sys/socket.h>
#include <netinet/in.h>
#include <arpa/inet.h>

int main() {
  // Create the socket
  int sockfd = socket(AF_INET, SOCK_STREAM, 0);
  if (sockfd < 0) {
    perror("Failed to create socket");
    return 1;
  }


  // Set up the server address
  struct sockaddr_in servaddr;
  memset(&servaddr, 0, sizeof(servaddr));
  servaddr.sin_family = AF_INET;
  servaddr.sin_port = htons(PORT);
  servaddr.sin_addr.s_addr = inet_addr("127.0.0.1");


  // Initiate the connection
  if (connect(sockfd, (struct sockaddr*)&servaddr, sizeof(servaddr)) < 0) {
    perror("Failed to connect to server");
    return 1;
  }


  // Send the SYN message
  char syn_msg[1] = {SYN};
  if (send(sockfd, syn_msg, sizeof(syn_msg), 0) < 0) {
    perror("Failed to send SYN message");
    return 1;
  }


  // Receive the SYN-ACK message
  char syn_ack_msg[1];
  if (recv(sockfd, syn_ack_msg, sizeof(syn_ack_msg), 0) < 0) {
    perror("Failed to receive SYN-ACK message");
    return 1;
  }


  // Check that the SYN-ACK message is valid
  if (syn_ack_msg[0] != SYN_ACK) {
    fprintf(stderr, "Invalid SYN-ACK message received\n");
    return 1;
  }


  // Send the ACK message
  char ack_msg[1] = {ACK};
  if (send(sockfd, ack_msg, sizeof(ack_msg), 0) < 0) {
    perror("Failed to send ACK message");
    return 1;
  }


  // The handshake is complete and the connection is established


  // Clean up and exit
  close(sockfd);
  return 0;
}
        